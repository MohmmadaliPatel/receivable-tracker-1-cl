# Copy this file to your Ubuntu server as the app directory `.env` (not /etc/environment).
# Replace YOUR_PUBLIC_HOST with your server IP or domain (no trailing slash).
#
# If you terminate TLS in nginx/caddy in front of Node, forward proto and host so session
# cookies use Secure and stay on the right host, e.g. nginx:
#   proxy_set_header Host $host;
#   proxy_set_header X-Forwarded-Host $host;
#   proxy_set_header X-Forwarded-Proto $scheme;
#
# Important: NEXT_PUBLIC_APP_BASE_URL is embedded at build time for this release package.
# If your public URL differs from the value recorded in BUILD_INFO.txt, contact your vendor for a rebuild.

PORT=3002

DEMO_MODE=false

NODE_ENV=production

DATABASE_URL="file:./dev.db"

EMAIL_ACTION_JWT_SECRET=replace-with-at-least-32-char-random-for-email-magic-links-jose-hs256  # REQUIRED; >=32 chars. Generate: openssl rand -base64 32
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3002

# Legacy (not used by main application flows)
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=use_a_long_random_string_in_production

# Security (optional — defaults shown)
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL_CHAR=true  # Required by default for stronger policy. Change only if you have a specific reason.
LOCKOUT_MAX_ATTEMPTS=3  # After 3 consecutive failures the account is locked for LOCKOUT_DURATION_MINUTES. On the 3rd lockout event, adminResetRequired is set and only an admin password reset can unlock the account.
LOCKOUT_DURATION_MINUTES=15
SESSION_MAX_AGE_DAYS=7
SESSION_IDLE_TIMEOUT_MINUTES=30
AUDIT_LOG_RETENTION_DAYS=90
# REQUIRED in production: protects POST /api/cron (start/stop/reload processing of email configs). Middleware denies if unset; route also requires admin session. Generate with: openssl rand -base64 32
CRON_API_SECRET=use_a_long_random_string_in_production
